<file path="curriculum/courses/new-testament-foundations-06-pauline-epistles/lessons/ntf06_lesson_26.json">
{
  "lesson_id": "ntf06_lesson_26",
  "course_id": "new_testament_foundations_06_pauline_epistles",
  "sequence": 26,
  "title": "Titus: Doctrine and Good Works",
  "objective": "Establish healthy churches through sound doctrine, qualified elders, and visible good works.",
  "duration": "8 minutes",
  "prerequisite": "ntf06_lesson_25",
  "required_passages": [
    {
      "passage_id": "tit_1_1_3_15",
      "reference": "Titus 1:1-3:15",
      "text": "Appoint elders in every town... hold firm to the trustworthy word... the grace of God has appeared... training us... to be zealous for good works... He saved us... by the washing of regeneration and renewal of the Holy Spirit."
    }
  ],
  "segments": [
    {
      "type": "orientation",
      "sequence": 1,
      "audio_script": "Titus shows how gospel truth forms healthy communities with credible public witness.",
      "word_count": 12
    },
    {
      "type": "reading",
      "sequence": 2,
      "audio_script": "Listen to Titus. Paul instructs Titus to appoint qualified elders, silence false teachers, and teach doctrine that produces self-controlled, honorable living across all ages. He grounds ethics in grace: God saved us not by works but by mercy, and this salvation trains believers to devote themselves to good works.",
      "word_count": 49
    },
    {
      "type": "context",
      "sequence": 3,
      "audio_script": "Churches in Crete needed strong leadership and consistent gospel-shaped conduct in a difficult cultural setting.",
      "word_count": 15
    },
    {
      "type": "analysis",
      "sequence": 4,
      "audio_script": "Sound doctrine and good works are inseparable. Grace is both saving and training, producing people who adorn the gospel in society.",
      "word_count": 21
    },
    {
      "type": "themes",
      "sequence": 5,
      "audio_script": "Key themes include elder qualification, doctrinal integrity, regeneration, sanctification, civic witness, and good works.",
      "word_count": 14
    },
    {
