.btn-chip.btn-chip-next:hover {
    background: #566fe0;
}

/* already completed segment */
.btn-chip.btn-chip-done {
    opacity: 0.45;
    color: #888;
    border-color: #ddd;
    background: #f5f5f5;
    cursor: default;
}

/* current/replay */
.btn-chip.btn-chip-current {
    opacity: 0.8;
    border-color: #667eea;
    color: #667eea;
}

.btn-chip.btn-chip-current:hover {
    background: #eef0ff;
}

.manual-command {
    display: flex;
    gap: 8px;
}

.manual-command input {
    flex: 1;
    padding: 10px 12px;
    border: 1px solid #e0e0e0;
    border-radius: 8px;
    font-size: 0.9em;
}

.btn-mic {
    background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    color: white;
    border: none;
    padding: 20px 40px;
