.btn-mic:hover {
    transform: translateY(-2px);
    box-shadow: 0 6px 20px rgba(102, 126, 234, 0.6);
}

.btn-mic:active {
    transform: translateY(0);
    background: linear-gradient(135deg, #764ba2 0%, #667eea 100%);
}

.mic-status {
    font-size: 0.9em;
    color: #999;
    margin-top: 10px;
}

.status-info {
    margin: 0 0 16px;
    padding: 12px 15px;
    background: #f9f9f9;
    border-radius: 8px;
    min-height: 30px;
}

.status {
    color: #666;
    font-size: 0.95em;
}

/* #8: Grouped bottom buttons */
.btn-group-utility {
    display: flex;
    gap: 8px;
    margin-bottom: 10px;
}

.btn-group-utility button {
    flex: 1;
}

.btn-group-nav {
    display: flex;
    gap: 8px;
    margin-bottom: 10px;
}

.btn-group-nav button {
    flex: 1;
}

.btn-exit-row {
    display: flex;
    align-items: center;
    gap: 10px;
    border-top: 1px solid #f0f0f0;
    padding-top: 12px;
    margin-top: 4px;
}

.btn-nav {
    background: #e8eaed;
    color: #444;
    border: none;
    padding: 10px 16px;
    border-radius: 8px;
    font-size: 0.95em;
    cursor: pointer;
    transition: background 0.2s ease;
}

.btn-nav:hover {
    background: #d8dce0;
}

.btn-nav-next {
    background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    color: white;
}

.btn-nav-next:hover {
    background: linear-gradient(135deg, #566fe0 0%, #6a3d92 100%);
}

/* #9: Debug toggle */
.btn-debug-toggle {
    background: none;
    border: none;
    color: #ccc;
    font-size: 0.75em;
    cursor: pointer;
    padding: 2px 4px;
    margin-left: auto;
    text-decoration: underline;
}

.btn-debug-toggle:hover {
    color: #999;
}

.btn-primary, .btn-secondary, .btn-danger {
    border: none;
    padding: 12px 30px;
    border-radius: 8px;
    font-size: 1em;
    cursor: pointer;
    transition: all 0.3s ease;
    margin-right: 10px;
    margin-bottom: 10px;
}

.btn-primary {
    background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    color: white;
}

.btn-primary:hover {
    transform: translateY(-2px);
    box-shadow: 0 4px 15px rgba(102, 126, 234, 0.4);
}

.btn-secondary {
    background: #4CAF50;
    color: white;
}

.btn-secondary:hover {
    background: #45a049;
}

.btn-danger {
    background: #f44336;
    color: white;
}

.btn-danger:hover {
    background: #da190b;
}

.error {
    background: white;
    border-radius: 12px;
    padding: 40px;
    text-align: center;
    box-shadow: 0 10px 40px rgba(0, 0, 0, 0.2);
}

.error p {
    color: #f44336;
    font-size: 1.1em;
