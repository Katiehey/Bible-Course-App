      "acceptable_variants": [
        "hebrews 9:22 — no remission without blood",
        "blood must be shed for forgiveness — there is no other way",
        "the atonement principle: forgiveness requires blood"
      ],
      "word_count": 21
    },
    {
      "type": "close",
      "sequence": 7,
      "audio_script": "Jesus secures full access to God forever. Next, Hebrews celebrates faith's endurance and practical holiness.",
      "word_count": 15
    }
  ],
  "metadata": {
    "difficulty": "intermediate",
    "testament": "new",
    "book": "hebrews",
    "chapter_range": "5-10",
    "theological_themes": [
      "covenant",
      "atonement",
      "priesthood",
      "assurance",
      "perseverance"
    ],
    "time_period": "circa_64_ad",
    "canonical_order": 58
  },
  "vocabulary": [
    {
      "term": "once for all",
      "definition": "The phrase in Hebrews 7:27, 9:12, and 10:10 describing Christ's sacrifice; unlike the repeated OT sacrifices, Christ's death was a single definitive act that permanently secured atonement"
    },
    {
      "term": "new covenant",
      "definition": "Hebrews 8-9 develops Jeremiah 31:31-34 as the better covenant Christ mediates; laws written on the heart, God as their God, and sins remembered no more — established by Christ's blood"
