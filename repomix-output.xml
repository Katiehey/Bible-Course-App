  "prerequisite": "ntf06_lesson_27",
  "required_passages": [
    {
      "passage_id": "heb_1_1_4_16",
      "reference": "Hebrews 1:1-4:16",
      "text": "Long ago... God spoke... by the prophets, but in these last days he has spoken to us by his Son... we have a great high priest... let us hold fast our confession."
    }
  ],
  "segments": [
