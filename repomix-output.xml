  "prerequisite": "ntf07_lesson_01",
  "required_passages": [
    {
      "passage_id": "heb_5_1_10_39",
      "reference": "Hebrews 5:1-10:39",
      "text": "You are a priest forever... We have this as a sure and steadfast anchor of the soul... Christ entered once for all... by means of his own blood... Let us hold fast the confession of our hope without wavering."
