}

@media (max-width: 600px) {
    .header h1 {
        font-size: 1.8em;
    }

    .tts-row {
        flex-direction: column;
        align-items: flex-start;
    }

    .tts-row label {
        width: auto;
    }

    .manual-command {
        flex-direction: column;
    }

    .btn-primary, .btn-secondary, .btn-danger {
        width: 100%;
        margin-right: 0;
        margin-bottom: 10px;
    }

    .step-label {
        font-size: 0.55em;
    }
}
