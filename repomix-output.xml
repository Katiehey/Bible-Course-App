    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
    background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 20px;
}

.container {
    max-width: 600px;
    width: 100%;
}

.header {
    text-align: center;
    color: white;
    margin-bottom: 30px;
}

.header h1 {
    font-size: 2.5em;
    margin-bottom: 10px;
}

.header p {
    font-size: 1.1em;
    opacity: 0.9;
}

.splash {
    background: white;
    border-radius: 12px;
    padding: 60px 30px;
    text-align: center;
    box-shadow: 0 10px 40px rgba(0, 0, 0, 0.2);
}

.splash h2 {
    font-size: 2em;
    margin-bottom: 20px;
    color: #333;
}

.splash p {
    color: #666;
    margin-bottom: 30px;
    font-size: 1.1em;
}

.lesson {
    background: white;
    border-radius: 12px;
    padding: 30px;
    box-shadow: 0 10px 40px rgba(0, 0, 0, 0.2);
}

.index-window {
    background: white;
    border-radius: 12px;
    padding: 24px;
    box-shadow: 0 10px 40px rgba(0, 0, 0, 0.2);
}

.index-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
    margin-bottom: 8px;
}

.index-header h2 {
    font-size: 1.5em;
    color: #333;
}

.index-subtitle {
    color: #666;
    margin-bottom: 12px;
}

#indexSearch {
    width: 100%;
    padding: 10px 12px;
    border: 1px solid #ddd;
    border-radius: 8px;
    font-size: 0.95em;
    margin-bottom: 14px;
}

.index-content {
    max-height: 65vh;
    overflow: auto;
    padding-right: 4px;
}

.index-course {
    border: 1px solid #ececec;
    border-radius: 10px;
    padding: 12px;
    margin-bottom: 12px;
}

/* #3: Course-level progress header */
.index-course-title {
    font-weight: 700;
    color: #2f3a7e;
    margin-bottom: 4px;
}

.index-course-progress {
    font-size: 0.8em;
    color: #888;
    margin-bottom: 8px;
}

.index-course-progress-bar {
    height: 4px;
    background: #eee;
    border-radius: 2px;
    margin-bottom: 10px;
    overflow: hidden;
}

.index-course-progress-fill {
    height: 100%;
    background: #4CAF50;
    border-radius: 2px;
    transition: width 0.3s ease;
}

.index-lesson-list {
    display: grid;
    gap: 8px;
}

.index-lesson-item {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 8px;
    background: #f8f9ff;
    border-radius: 8px;
    padding: 8px 10px;
}

/* #3: Completed lesson styling in index */
.index-lesson-item.index-lesson-done {
    background: #f0fff4;
}

.index-lesson-meta {
    color: #444;
    font-size: 0.9em;
}

.lesson-done-badge {
    color: #4CAF50;
    font-weight: bold;
    margin-right: 2px;
}

.index-open-btn {
    background: #667eea;
    color: #fff;
    border: none;
    border-radius: 6px;
    padding: 6px 10px;
    font-size: 0.85em;
    cursor: pointer;
    white-space: nowrap;
}

.index-open-btn:hover {
    background: #566fe0;
}

/* #9: Debug panel - always hidden until toggled */
.debug-panel {
    background: #111;
    color: #d1f7c4;
    padding: 10px;
    border-radius: 8px;
    margin-bottom: 15px;
    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, "Liberation Mono", "Courier New", monospace;
    font-size: 12px;
    max-height: 180px;
    overflow: auto;
}

.debug-header {
    font-weight: 600;
    margin-bottom: 6px;
    color: #7ee787;
    display: flex;
    justify-content: space-between;
    align-items: center;
}

.btn-debug-close {
    background: none;
    border: 1px solid #555;
    color: #aaa;
    font-size: 0.75em;
    cursor: pointer;
    padding: 1px 6px;
    border-radius: 3px;
}

.hidden {
    display: none !important;
}

.lesson-header {
    text-align: center;
    margin-bottom: 20px;
    border-bottom: 2px solid #f0f0f0;
    padding-bottom: 16px;
}

.lesson-header h2 {
    font-size: 1.8em;
    color: #333;
    margin-bottom: 10px;
}

.lesson-id {
    color: #999;
    font-size: 0.9em;
}

/* #7: 7-dot step indicator */
.segment-steps {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 20px;
    padding: 12px 10px 8px;
    background: #f9f9f9;
    border-radius: 8px;
    overflow-x: auto;
}

.step-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 5px;
    flex: 0 0 auto;
}

.step-dot {
    width: 14px;
    height: 14px;
    border-radius: 50%;
    background: #ddd;
    border: 2px solid #ccc;
    transition: all 0.25s ease;
}

.step-label {
    font-size: 0.6em;
    color: #bbb;
    text-align: center;
    white-space: nowrap;
}

.step-divider {
    flex: 1;
    height: 2px;
    background: #ddd;
    min-width: 4px;
    margin-bottom: 18px;
    transition: background 0.25s ease;
}

.step-item.step-done .step-dot {
    background: #4CAF50;
    border-color: #4CAF50;
}

.step-item.step-done .step-label {
    color: #4CAF50;
}

.step-item.step-done + .step-divider {
    background: #4CAF50;
}

.step-item.step-current .step-dot {
    background: #667eea;
    border-color: #667eea;
    box-shadow: 0 0 0 3px rgba(102, 126, 234, 0.25);
    transform: scale(1.25);
}

.step-item.step-current .step-label {
    color: #667eea;
    font-weight: 700;
}

.audio-display {
    background: #f5f7fa;
    border-left: 4px solid #667eea;
    padding: 20px;
    border-radius: 8px;
    margin: 0 0 20px;
    min-height: 80px;
}

.audio-script {
    color: #555;
    line-height: 1.6;
    font-size: 1em;
}

.controls {
    text-align: center;
    margin: 20px 0;
}

/* #10: TTS settings as collapsible details */
.tts-settings {
    background: #f9f9ff;
    padding: 10px 12px;
    border-radius: 10px;
    margin: 0 0 16px;
}

.tts-settings summary {
    color: #667eea;
    font-size: 0.9em;
    font-weight: 600;
    cursor: pointer;
    user-select: none;
    list-style: none;
    display: flex;
    align-items: center;
    gap: 4px;
}

.tts-settings summary::-webkit-details-marker {
    display: none;
}

.tts-settings summary::after {
    content: ' ▸';
    font-size: 0.8em;
    color: #999;
}

.tts-settings[open] summary {
    margin-bottom: 10px;
}

.tts-settings[open] summary::after {
    content: ' ▾';
}

.tts-row {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 8px;
}

.tts-row label {
    width: 60px;
    font-size: 0.9em;
    color: #555;
}

.tts-row select,
.tts-row input[type="range"] {
    flex: 1;
}

#rateValue {
    width: 48px;
    text-align: right;
    font-size: 0.85em;
    color: #555;
}

/* #5 + #6: Command buttons with contextual states */
.quick-commands {
    background: #f7f8ff;
    padding: 15px;
    border-radius: 10px;
    margin: 0 0 16px;
}

.quick-commands h3 {
    color: #667eea;
    margin-bottom: 10px;
    font-size: 0.95em;
}

.command-buttons {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-bottom: 12px;
}

.btn-chip {
    border: 1px solid #dfe3ff;
    background: white;
    color: #4b5bdc;
    padding: 8px 12px;
    border-radius: 999px;
    font-size: 0.85em;
    cursor: pointer;
    transition: all 0.2s ease;
    opacity: 0.4;
