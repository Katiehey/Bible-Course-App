<file path="curriculum/courses/new-testament-foundations-06-pauline-epistles/lessons/ntf06_lesson_23.json">
{
  "lesson_id": "ntf06_lesson_23",
  "course_id": "new_testament_foundations_06_pauline_epistles",
  "sequence": 23,
  "title": "1 Timothy: Guard the Deposit",
  "objective": "Persevere in pastoral ministry through Scripture-centered teaching, godliness, and wise care for the flock.",
  "duration": "9 minutes",
  "prerequisite": "ntf06_lesson_22",
  "required_passages": [
    {
      "passage_id": "1ti_4_1_6_21",
      "reference": "1 Timothy 4:1-6:21",
      "text": "Train yourself for godliness... devote yourself to the public reading of Scripture... godliness with contentment is great gain... fight the good fight of the faith... guard the deposit entrusted to you."
    }
  ],
  "segments": [
    {
      "type": "orientation",
      "sequence": 1,
      "audio_script": "Paul equips Timothy for long-term, faithful shepherding in difficult times.",
      "word_count": 10
    },
    {
      "type": "reading",
      "sequence": 2,
      "audio_script": "Listen to 1 Timothy 4-6. Paul warns of later deceptions and calls Timothy to nourish the church with sound words. He emphasizes Scripture reading, teaching, and personal example. He gives instructions for caring for widows, honoring elders, and resisting greed. He charges Timothy to fight the good fight and keep the commandment unstained.",
      "word_count": 53
    },
    {
      "type": "context",
      "sequence": 3,
      "audio_script": "Pastoral ministry required both doctrinal vigilance and practical administration in diverse church needs.",
      "word_count": 13
    },
    {
      "type": "analysis",
      "sequence": 4,
      "audio_script": "Faithful ministry is sustained by Scripture, godly character, and endurance. Contentment protects against corrosive love of money. Guarding truth requires both courage and tenderness.",
      "word_count": 24
    },
    {
      "type": "themes",
      "sequence": 5,
      "audio_script": "Key themes include godliness, Scripture ministry, pastoral care, generosity, contentment, and perseverance.",
      "word_count": 12
    },
    {
      "type": "question",
      "sequence": 6,
      "audio_script": "Review question: What does Paul say Timothy should flee and what should he pursue in 1 Timothy 6? Answer: flee the love of money and the desires it brings; pursue righteousness, godliness, faith, love, steadfastness, and gentleness.",
      "correct_answer": "flee love of money; pursue righteousness, godliness, faith, love, steadfastness, and gentleness",
      "acceptable_variants": [
        "run from greed and pursue righteousness godliness faith love patience meekness",
        "1 timothy 6 — the man of god flees worldly desires and chases godly virtues",
        "timothy is told to flee covetousness and follow after six spiritual qualities"
      ],
      "word_count": 37
    },
    {
      "type": "close",
      "sequence": 7,
      "audio_script": "Guard the gospel with faithful life and teaching. Next, Paul's final letter calls Timothy to finish well.",
      "word_count": 17
    }
  ],
  "metadata": {
    "difficulty": "intermediate",
    "testament": "new",
    "book": "1_timothy",
    "chapter_range": "4-6",
    "theological_themes": [
      "godliness",
      "scripture",
      "pastoral_care",
      "contentment",
      "perseverance"
    ],
    "time_period": "circa_63_ad",
    "canonical_order": 54
  },
  "vocabulary": [
    {
      "term": "love of money",
      "definition": "What Paul calls a root of all kinds of evil in 1 Timothy 6:10; he is not condemning wealth itself but the greed that treats money as the source of life and security rather than God"
    },
    {
      "term": "deposit",
      "definition": "The Greek paratheke meaning something entrusted for safekeeping; Paul uses it in 1 Timothy 6:20 and 2 Timothy 1:14 for the gospel truth entrusted to Timothy to guard and pass on"
    }
  ]
}
</file>

<file path="curriculum/courses/new-testament-foundations-06-pauline-epistles/lessons/ntf06_lesson_24.json">
{
  "lesson_id": "ntf06_lesson_24",
  "course_id": "new_testament_foundations_06_pauline_epistles",
  "sequence": 24,
  "title": "2 Timothy: Fan into Flame",
  "objective": "Receive Paul's final charge to courageous gospel endurance in suffering.",
  "duration": "9 minutes",
  "prerequisite": "ntf06_lesson_23",
  "required_passages": [
    {
      "passage_id": "2ti_1_1_2_26",
      "reference": "2 Timothy 1:1-2:26",
      "text": "God gave us a spirit not of fear but of power... share in suffering for the gospel... guard the good deposit... entrust to faithful men... endure hardship as a good soldier of Christ Jesus."
    }
  ],
  "segments": [
    {
      "type": "orientation",
      "sequence": 1,
      "audio_script": "From prison and near death, Paul calls Timothy to courage, loyalty, and multiplication.",
      "word_count": 13
    },
    {
      "type": "reading",
      "sequence": 2,
      "audio_script": "Listen to 2 Timothy 1-2. Paul urges Timothy to fan into flame his gift and not be ashamed of gospel testimony. He calls him to suffer with strength from grace, entrust truth to faithful teachers, and avoid quarrels while correcting opponents with gentleness.",
      "word_count": 43
    },
    {
      "type": "context",
      "sequence": 3,
      "audio_script": "Paul writes under Nero's hostility, aware his life is ending. This is a final leadership handoff.",
      "word_count": 16
    },
    {
      "type": "analysis",
      "sequence": 4,
      "audio_script": "Courage is Spirit-enabled, not personality-driven. Gospel ministry multiplies through entrusting truth to faithful people. Endurance requires disciplined focus and gentle doctrine-centered correction.",
      "word_count": 22
    },
    {
      "type": "themes",
      "sequence": 5,
      "audio_script": "Key themes include courage, suffering, discipleship multiplication, doctrinal fidelity, and servant character.",
      "word_count": 12
    },
    {
      "type": "question",
      "sequence": 6,
      "audio_script": "Review question: What does Paul say God gave believers in 2 Timothy 1:7 instead of a spirit of fear? Answer: a spirit of power, love, and self-discipline.",
      "correct_answer": "a spirit of power, love, and self-discipline",
      "acceptable_variants": [
        "power love and a sound mind — not a spirit of timidity",
        "god's spirit brings power and love and self-control not fear",
        "2 timothy 1:7 — the spirit given is one of power love and sound judgment"
      ],
      "word_count": 27
    },
    {
      "type": "close",
      "sequence": 7,
      "audio_script": "Fan into flame the gift and endure. Next, Paul grounds final perseverance in Scripture and Christ's appearing.",
      "word_count": 17
    }
  ],
  "metadata": {
    "difficulty": "intermediate",
    "testament": "new",
    "book": "2_timothy",
    "chapter_range": "1-2",
    "theological_themes": [
      "courage",
      "suffering",
      "discipleship",
      "doctrine",
      "endurance"
    ],
    "time_period": "circa_66_ad",
    "canonical_order": 55
  },
  "vocabulary": [
    {
      "term": "fan into flame",
      "definition": "Paul's command in 2 Timothy 1:6 to stir up the gift of God in Timothy; the image is of rekindling smoldering embers — a call to active, courageous use of spiritual gifting"
    },
    {
      "term": "soldier, athlete, farmer",
      "definition": "Three analogies in 2 Timothy 2:3-7 for the Christian life — each requires focused endurance and willingness to suffer; Paul uses them to encourage Timothy to persevere under hardship"
    }
  ]
}
</file>

<file path="curriculum/courses/new-testament-foundations-06-pauline-epistles/lessons/ntf06_lesson_25.json">
