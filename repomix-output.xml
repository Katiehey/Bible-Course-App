<file path="curriculum/courses/new-testament-foundations-05-acts/lessons/ntf05_lesson_12.json">
{
  "lesson_id": "ntf05_lesson_12",
  "course_id": "new_testament_foundations_05_acts",
  "sequence": 12,
  "title": "To the Ends of the Earth",
  "objective": "Conclude Acts by tracing Paul's trials, voyage, shipwreck, and final gospel witness in Rome.",
  "duration": "10 minutes",
  "prerequisite": "ntf05_lesson_11",
  "required_passages": [
    {
      "passage_id": "act_24_1_28_31",
      "reference": "Acts 24:1-28:31",
      "text": "Paul testified before Felix, Festus, and Agrippa... 'I stand here testifying... saying nothing but what the prophets and Moses said would come to pass: that the Christ must suffer and... rise from the dead.' ... he appealed to Caesar... endured storm and shipwreck... in Rome he proclaimed the kingdom of God and taught about the Lord Jesus Christ with all boldness and without hindrance."
    }
  ],
  "segments": [
    {
      "type": "orientation",
      "sequence": 1,
      "audio_script": "Acts ends with a prisoner preacher carrying the gospel to Rome. Today we see trials, storms, and unstoppable witness.",
      "word_count": 19
    },
    {
      "type": "reading",
      "sequence": 2,
      "audio_script": "Listen to Acts 24 through 28. Paul defended the faith before governors Felix and Festus and before King Agrippa, insisting he proclaimed only what Moses and the prophets foretold: Messiah's suffering and resurrection. To avoid unjust transfer, Paul appealed to Caesar. On the voyage to Rome, a violent storm struck. Paul encouraged all aboard with God's promise that lives would be spared though the ship would be lost. They were shipwrecked on Malta, where Paul ministered with signs and healing. Finally arriving in Rome, Paul met Jewish leaders and explained the kingdom of God from Moses and the Prophets, persuading some while others disbelieved. Acts closes with Paul under house arrest, proclaiming Jesus Christ with all boldness and without hindrance.",
      "word_count": 120
    },
    {
      "type": "context",
      "sequence": 3,
      "audio_script": "Rome was the empire's center. Reaching Rome symbolizes the gospel's advance to the nations. Luke leaves Paul's final outcome unstated, focusing instead on the unhindered word.",
      "word_count": 26
    },
    {
      "type": "analysis",
      "sequence": 4,
      "audio_script": "Acts closes open-ended to show the mission continues through the church. Political trials become evangelistic opportunities. Providence governs storms and courts alike. The kingdom message remains rooted in Scripture and centered on Jesus' death and resurrection. 'Without hindrance' summarizes God's unstoppable mission.",
      "word_count": 42
    },
    {
      "type": "themes",
      "sequence": 5,
      "audio_script": "Key themes include faithful legal defense, scriptural fulfillment, resurrection proclamation, perseverance in hardship, providence in danger, mission to imperial centers, and unhindered gospel advance.",
      "word_count": 24
    },
    {
      "type": "question",
      "sequence": 6,
      "audio_script": "Review question: How does the book of Acts end, and what is Paul doing? Answer: Paul is in Rome under house arrest, boldly proclaiming the kingdom of God and teaching about Jesus with no one hindering him.",
      "correct_answer": "Paul in Rome under house arrest, openly proclaiming the kingdom of God and teaching about Jesus",
      "acceptable_variants": [
        "acts ends with paul in rome preaching freely and without hindrance",
        "the gospel reaches rome — paul teaches boldly though under arrest",
        "acts 28 — paul proclaims the kingdom in rome with boldness and without obstacle"
      ],
      "word_count": 37
    },
    {
      "type": "close",
      "sequence": 7,
      "audio_script": "Acts ends with the gospel advancing in Rome, and the mission continues through us today. Next we move into Pauline Epistles.",
      "word_count": 21
    }
  ],
  "metadata": {
    "difficulty": "intermediate",
    "testament": "new",
    "book": "acts",
    "chapter_range": "24-28",
    "theological_themes": [
      "trials",
      "providence",
      "shipwreck",
      "witness",
      "rome",
      "unhindered_gospel"
    ],
    "time_period": "circa_60_ad",
    "canonical_order": 44
  },
  "vocabulary": [
    {
      "term": "Rome",
      "definition": "The final destination of Acts and the center of the empire; Paul's arrival fulfills Acts 1:8 and Jesus' promise in Acts 23:11 that Paul must testify in Rome — the ends of the earth"
    },
    {
      "term": "without hindrance",
      "definition": "The final word of Acts in Greek (akolutos) — Paul preached without hindrance; despite chains and opposition, the word of God was not chained — a triumphant ending to the gospel's advance"
    }
  ]
}
</file>

<file path="curriculum/courses/new-testament-foundations-06-pauline-epistles/lessons/ntf06_lesson_01.json">
{
  "lesson_id": "ntf06_lesson_01",
  "course_id": "new_testament_foundations_06_pauline_epistles",
  "sequence": 1,
  "title": "Romans: Gospel Power",
  "objective": "Grasp Paul's thesis that the gospel reveals God's righteousness for salvation by faith.",
  "duration": "9 minutes",
  "prerequisite": "ntf05_lesson_12",
  "required_passages": [
    {
      "passage_id": "rom_1_1_17",
      "reference": "Romans 1:1-17",
      "text": "I am not ashamed of the gospel, for it is the power of God for salvation to everyone who believes... For in it the righteousness of God is revealed from faith for faith."
    }
  ],
  "segments": [
    {
      "type": "orientation",
      "sequence": 1,
      "audio_script": "Paul's letters begin with Romans, his fullest gospel explanation. Today we focus on the message that saves.",
      "word_count": 17
    },
    {
      "type": "reading",
      "sequence": 2,
      "audio_script": "Listen to Romans 1:1-17. Paul introduces himself as an apostle set apart for the gospel promised in Scripture concerning God's Son. He longs to preach in Rome and declares, 'I am not ashamed of the gospel... it is the power of God for salvation to everyone who believes.'",
      "word_count": 48
    },
    {
      "type": "context",
      "sequence": 3,
      "audio_script": "Romans addresses a mixed Jewish-Gentile church and prepares for mission to Spain. Paul lays doctrinal foundations before practical exhortations.",
      "word_count": 19
    },
    {
      "type": "analysis",
      "sequence": 4,
      "audio_script": "The gospel is not advice but divine power. Salvation comes by faith, not ethnicity or law performance. God's righteousness is both revealed and received in Christ.",
      "word_count": 26
    },
    {
      "type": "themes",
      "sequence": 5,
      "audio_script": "Key themes include gospel centrality, righteousness by faith, global mission, and confidence in Christ.",
      "word_count": 14
    },
    {
      "type": "question",
      "sequence": 6,
      "audio_script": "Review question: What does Paul declare in Romans 1:16-17 about the gospel? Answer: he is not ashamed of it, for it is the power of God for salvation to everyone who believes, and in it God's righteousness is revealed from faith to faith.",
      "correct_answer": "the gospel is God's power for salvation — revealing righteousness from faith to faith",
      "acceptable_variants": [
        "I am not ashamed of the gospel — it is God's power for salvation to all who believe",
        "in the gospel god's righteousness is revealed from faith for faith",
        "romans 1:16-17 — the power of salvation by faith for all"
      ],
      "word_count": 43
    },
    {
      "type": "close",
      "sequence": 7,
      "audio_script": "The gospel saves all who believe. Next, Paul shows humanity's universal need for grace.",
      "word_count": 14
    }
  ],
  "metadata": {
    "difficulty": "intermediate",
    "testament": "new",
    "book": "romans",
    "chapter_range": "1",
    "theological_themes": [
      "gospel",
      "righteousness",
      "faith",
      "salvation"
    ],
    "time_period": "circa_57_ad",
    "canonical_order": 45
  },
  "vocabulary": [
    {
      "term": "righteousness of God",
      "definition": "The central theme of Romans; God's righteousness is both his character attribute and the gift he gives to believers through faith in Christ — declared righteous, not merely treated as if righteous"
    },
    {
      "term": "apostle",
      "definition": "One sent with a commission; Paul identifies himself as an apostle set apart for the gospel in Romans 1:1 — establishing his authority and the divine origin of his message"
    }
  ]
}
</file>

<file path="curriculum/courses/new-testament-foundations-06-pauline-epistles/lessons/ntf06_lesson_02.json">
{
  "lesson_id": "ntf06_lesson_02",
  "course_id": "new_testament_foundations_06_pauline_epistles",
  "sequence": 2,
  "title": "Romans: Justified by Faith",
  "objective": "Understand universal sin and God's provision of justification through Jesus Christ.",
  "duration": "10 minutes",
  "prerequisite": "ntf06_lesson_01",
  "required_passages": [
    {
      "passage_id": "rom_1_18_4_25",
      "reference": "Romans 1:18-4:25",
      "text": "All have sinned and fall short of the glory of God, and are justified by his grace as a gift... For we hold that one is justified by faith apart from works of the law."
    }
  ],
  "segments": [
    {
      "type": "orientation",
      "sequence": 1,
      "audio_script": "Paul diagnoses the human condition and announces God's gracious verdict: justified by faith.",
      "word_count": 13
    },
    {
      "type": "reading",
      "sequence": 2,
      "audio_script": "Listen to Romans 1:18-4:25. Paul shows Gentiles and Jews alike are under sin. No one is righteous on their own. But now God's righteousness is manifested apart from the law through faith in Jesus Christ. Abraham himself was counted righteous by faith, not works.",
      "word_count": 44
    },
    {
      "type": "context",
      "sequence": 3,
      "audio_script": "Paul addresses boasting and division by placing all people at the same level before God: guilty without Christ, accepted in Christ.",
      "word_count": 21
    },
    {
      "type": "analysis",
      "sequence": 4,
      "audio_script": "Justification is God's legal declaration that sinners are righteous because of Christ's atoning work. It is received by faith alone, excluding boasting and uniting believers.",
      "word_count": 25
    },
    {
      "type": "themes",
      "sequence": 5,
      "audio_script": "Key themes include universal sin, grace, atonement, justification, faith apart from works, and unity of Jew and Gentile.",
      "word_count": 18
    },
    {
      "type": "question",
      "sequence": 6,
      "audio_script": "Review question: What does Paul say Abraham's faith was counted as in Romans 4? Answer: righteousness — Abraham believed God and it was credited to him as righteousness.",
      "correct_answer": "righteousness — Abraham believed God and it was counted to him as righteousness",
      "acceptable_variants": [
        "his faith was reckoned as righteousness before circumcision",
        "romans 4 — faith counted as righteousness for abraham as model for all believers",
        "genesis 15:6 — abraham believed and it was counted to him as righteousness"
      ],
      "word_count": 28
    },
    {
      "type": "close",
      "sequence": 7,
      "audio_script": "God justifies sinners by grace through faith. Next, Paul unfolds assurance, sanctification, and life in the Spirit.",
      "word_count": 17
    }
  ],
  "metadata": {
    "difficulty": "intermediate",
    "testament": "new",
    "book": "romans",
    "chapter_range": "1-4",
    "theological_themes": [
      "sin",
      "justification",
      "grace",
      "faith"
    ],
    "time_period": "circa_57_ad",
    "canonical_order": 45
  },
  "vocabulary": [
    {
      "term": "justification",
      "definition": "The act of God declaring a sinner righteous on the basis of Christ's righteousness received through faith; Paul develops this in Romans 3-5 as the answer to universal human guilt before a holy God"
    },
    {
      "term": "imputation",
      "definition": "The crediting of righteousness to the believer's account; Paul quotes Genesis 15:6 in Romans 4 — faith was counted as righteousness — as the model of justification apart from works"
    }
  ]
}
</file>

<file path="curriculum/courses/new-testament-foundations-06-pauline-epistles/lessons/ntf06_lesson_03.json">
{
  "lesson_id": "ntf06_lesson_03",
  "course_id": "new_testament_foundations_06_pauline_epistles",
  "sequence": 3,
  "title": "Romans: New Life in the Spirit",
  "objective": "Learn how union with Christ brings freedom from sin's dominion and life by the Spirit.",
  "duration": "10 minutes",
  "prerequisite": "ntf06_lesson_02",
  "required_passages": [
    {
      "passage_id": "rom_5_1_8_39",
      "reference": "Romans 5:1-8:39",
      "text": "There is therefore now no condemnation for those who are in Christ Jesus... the law of the Spirit of life has set you free... nothing will be able to separate us from the love of God in Christ Jesus our Lord."
    }
  ],
  "segments": [
    {
      "type": "orientation",
      "sequence": 1,
      "audio_script": "From peace with God to victory in the Spirit, Romans 5-8 anchors Christian assurance and transformation.",
      "word_count": 16
    },
    {
      "type": "reading",
      "sequence": 2,
      "audio_script": "Listen to Romans 5-8. Justified believers have peace with God. In Adam came death; in Christ comes life. Believers are united with Christ in His death and resurrection, no longer slaves of sin. Though the struggle with indwelling sin is real, the Spirit empowers obedience. Paul triumphantly declares: no condemnation in Christ and no separation from God's love.",
      "word_count": 58
    },
    {
      "type": "context",
      "sequence": 3,
      "audio_script": "Paul writes pastorally to believers wrestling with assurance and holiness in a broken world.",
      "word_count": 14
    },
    {
      "type": "analysis",
      "sequence": 4,
      "audio_script": "Sanctification is grounded in identity: believers are in Christ. The Spirit does not merely improve behavior; He gives new life, adoption, and hope. Suffering cannot cancel God's covenant love.",
      "word_count": 29
    },
    {
      "type": "themes",
      "sequence": 5,
      "audio_script": "Key themes include union with Christ, sanctification, Spirit-led life, adoption, suffering with hope, assurance, and perseverance.",
      "word_count": 16
    },
    {
      "type": "question",
      "sequence": 6,
      "audio_script": "Review question: What does Paul say in Romans 8:1 about those who are in Christ Jesus? Answer: there is therefore now no condemnation for those who are in Christ Jesus.",
      "correct_answer": "there is therefore now no condemnation for those who are in Christ Jesus",
      "acceptable_variants": [
        "no condemnation now for those in christ",
        "romans 8:1 — freedom from condemnation for all who are in christ",
        "the great declaration — no condemnation for the believer"
      ],
      "word_count": 30
    },
    {
      "type": "close",
      "sequence": 7,
      "audio_script": "Life in the Spirit produces holiness and hope. Next, Paul addresses Israel, mercy, and practical Christian living.",
      "word_count": 17
    }
  ],
  "metadata": {
    "difficulty": "intermediate",
    "testament": "new",
    "book": "romans",
    "chapter_range": "5-8",
    "theological_themes": [
      "union_with_christ",
      "sanctification",
      "holy_spirit",
      "assurance"
    ],
    "time_period": "circa_57_ad",
    "canonical_order": 45
  },
  "vocabulary": [
    {
      "term": "union with Christ",
      "definition": "Paul's phrase in Christ expressing the believer's incorporation into Jesus through faith; it governs Romans 6-8 and carries consequences of death to sin, freedom from condemnation, and the Spirit's indwelling"
    },
    {
      "term": "Spirit of adoption",
      "definition": "The Spirit described in Romans 8:15 by whom believers cry Abba Father; adoption establishes the believer as a child and heir of God alongside Jesus"
    }
  ]
}
</file>

<file path="curriculum/courses/new-testament-foundations-06-pauline-epistles/lessons/ntf06_lesson_04.json">
{
  "lesson_id": "ntf06_lesson_04",
  "course_id": "new_testament_foundations_06_pauline_epistles",
  "sequence": 4,
  "title": "Romans: Mercy and Mission",
  "objective": "Summarize God's faithfulness, transformed ethics, and gospel mission in Romans 9-16.",
  "duration": "9 minutes",
  "prerequisite": "ntf06_lesson_03",
  "required_passages": [
    {
      "passage_id": "rom_9_1_16_27",
      "reference": "Romans 9:1-16:27",
      "text": "Oh, the depth of the riches... of God! ... Present your bodies as a living sacrifice... Love one another... Welcome one another as Christ has welcomed you... I make it my ambition to preach the gospel where Christ has not been named."
    }
  ],
  "segments": [
    {
      "type": "orientation",
      "sequence": 1,
      "audio_script": "Romans ends by joining deep theology to transformed community and outward mission.",
      "word_count": 12
    },
    {
      "type": "reading",
      "sequence": 2,
      "audio_script": "Listen to Romans 9-16. Paul wrestles with Israel's unbelief while affirming God's sovereign mercy and covenant faithfulness. He calls believers to offer themselves as living sacrifices, renew their minds, love genuinely, submit appropriately, and welcome one another across differences. He then shares his missionary ambition and partnership vision.",
      "word_count": 48
    },
    {
      "type": "context",
      "sequence": 3,
      "audio_script": "Roman house churches faced ethnic and conscience tensions. Paul applies gospel truth to unity and witness.",
      "word_count": 16
    },
    {
      "type": "analysis",
      "sequence": 4,
      "audio_script": "Doctrine fuels discipleship. Worship is whole-life surrender. Unity requires mutual welcome under Christ's lordship. Mature churches become mission bases for unreached peoples.",
      "word_count": 22
    },
    {
      "type": "themes",
      "sequence": 5,
      "audio_script": "Key themes include God's mercy, humility before mystery, sacrificial living, Christian unity, conscience wisdom, and frontier mission.",
      "word_count": 17
    },
    {
      "type": "question",
      "sequence": 6,
      "audio_script": "Review question: What does Paul say in Romans 12:1-2 that believers should do with their bodies? Answer: present them as living sacrifices, holy and pleasing to God — this is spiritual worship; do not conform to this age but be transformed by renewing the mind.",
      "correct_answer": "present your bodies as living sacrifices to God and be transformed by renewing your mind",
      "acceptable_variants": [
        "offer bodies as living sacrifices and do not conform to the world",
        "romans 12 — living sacrifice and mind renewal as the response to God's mercy",
        "spiritual worship is the body presented to god and the mind transformed"
      ],
      "word_count": 45
    },
    {
      "type": "close",
      "sequence": 7,
      "audio_script": "Romans forms a complete gospel vision for belief, belonging, and mission. Next we turn to Corinth's church struggles.",
      "word_count": 18
    }
  ],
  "metadata": {
    "difficulty": "intermediate",
    "testament": "new",
    "book": "romans",
    "chapter_range": "9-16",
    "theological_themes": [
      "mercy",
      "election",
      "ethics",
      "unity",
      "mission"
    ],
    "time_period": "circa_57_ad",
    "canonical_order": 45
  },
  "vocabulary": [
    {
      "term": "living sacrifice",
      "definition": "Paul's term in Romans 12:1 for the believer's total offering of their life to God; worship extends beyond ritual to every dimension of daily embodied existence"
    },
    {
      "term": "spiritual gifts in Romans 12",
      "definition": "The gifts Paul lists in Romans 12:6-8 including prophecy, service, teaching, exhortation, giving, leadership, and mercy; they are to be exercised with sober judgment within the body of Christ"
    }
  ]
}
</file>

<file path="curriculum/courses/new-testament-foundations-06-pauline-epistles/lessons/ntf06_lesson_05.json">
{
  "lesson_id": "ntf06_lesson_05",
  "course_id": "new_testament_foundations_06_pauline_epistles",
  "sequence": 5,
  "title": "1 Corinthians: Christ over Division",
  "objective": "Address church factions and re-center identity, wisdom, and leadership in Christ crucified.",
  "duration": "9 minutes",
  "prerequisite": "ntf06_lesson_04",
  "required_passages": [
    {
      "passage_id": "1co_1_1_4_21",
      "reference": "1 Corinthians 1:1-4:21",
      "text": "Is Christ divided? ... We preach Christ crucified... Let no one boast in men... servants through whom you believed... The kingdom of God does not consist in talk but in power."
    }
  ],
  "segments": [
    {
      "type": "orientation",
      "sequence": 1,
      "audio_script": "Corinth's gifted church was fractured by pride. Paul calls them back to the cross.",
      "word_count": 14
    },
    {
      "type": "reading",
      "sequence": 2,
      "audio_script": "Listen to 1 Corinthians 1-4. Paul confronts party spirit: 'I follow Paul,' 'I follow Apollos.' He asks, 'Is Christ divided?' He insists the center is Christ crucified, which appears foolish to the world but is God's wisdom and power. Leaders are servants and stewards, not celebrities.",
      "word_count": 46
    },
    {
      "type": "context",
      "sequence": 3,
      "audio_script": "Corinth valued status, rhetoric, and power. These cultural values leaked into church identity.",
      "word_count": 13
    },
    {
      "type": "analysis",
      "sequence": 4,
      "audio_script": "When churches orbit personalities, the cross is displaced. Gospel maturity rejects boasting and embraces humble service. True leadership builds on Christ, not brand.",
      "word_count": 23
    },
    {
      "type": "themes",
      "sequence": 5,
      "audio_script": "Key themes include unity in Christ, folly of worldly wisdom, centrality of the cross, servant leadership, and spiritual maturity.",
      "word_count": 19
    },
    {
      "type": "question",
      "sequence": 6,
      "audio_script": "Review question: What does Paul say is foolish to God in 1 Corinthians 1? Answer: the wisdom of the world — God chose the foolish things to shame the wise and the weak things to shame the strong.",
      "correct_answer": "the wisdom of the world is foolishness to God — he chose what is weak and foolish to shame the strong",
      "acceptable_variants": [
        "worldly wisdom is foolishness — god's foolishness is wiser than human wisdom",
        "the cross appears foolish to those perishing but is God's power to those being saved",
        "1 corinthians 1 — god chose the weak and foolish to nullify the wise and powerful"
      ],
      "word_count": 38
    },
    {
      "type": "close",
      "sequence": 7,
      "audio_script": "The cross heals division by humbling all. Next, Paul confronts holiness, discipline, and embodied witness.",
      "word_count": 15
    }
  ],
  "metadata": {
    "difficulty": "intermediate",
    "testament": "new",
    "book": "1_corinthians",
    "chapter_range": "1-4",
    "theological_themes": [
      "unity",
      "cross",
      "wisdom",
      "leadership"
    ],
    "time_period": "circa_55_ad",
    "canonical_order": 46
  },
  "vocabulary": [
    {
      "term": "word of the cross",
      "definition": "Paul's term in 1 Corinthians 1:18 for the gospel message about Christ crucified; it is foolishness to those perishing but the power of God to those being saved"
    },
    {
      "term": "divisions at Corinth",
      "definition": "The factional allegiances in the Corinthian church (Paul, Apollos, Cephas, Christ) addressed in 1 Corinthians 1-4; Paul argues that boasting in human leaders contradicts the cross"
    }
  ]
}
</file>

<file path="curriculum/courses/new-testament-foundations-06-pauline-epistles/lessons/ntf06_lesson_06.json">
{
  "lesson_id": "ntf06_lesson_06",
  "course_id": "new_testament_foundations_06_pauline_epistles",
  "sequence": 6,
  "title": "1 Corinthians: Holy Bodies, Holy Community",
  "objective": "Apply gospel holiness to sexuality, lawsuits, marriage, and liberty in everyday life.",
  "duration": "10 minutes",
  "prerequisite": "ntf06_lesson_05",
  "required_passages": [
    {
      "passage_id": "1co_5_1_10_33",
      "reference": "1 Corinthians 5:1-10:33",
      "text": "Do you not know that a little leaven leavens the whole lump?... Flee from sexual immorality... you are not your own, for you were bought with a price... whether you eat or drink, do all to the glory of God."
    }
  ],
  "segments": [
    {
      "type": "orientation",
      "sequence": 1,
      "audio_script": "Paul applies the gospel to messy church life: discipline, sexuality, relationships, and conscience.",
      "word_count": 13
    },
    {
      "type": "reading",
      "sequence": 2,
      "audio_script": "Listen to 1 Corinthians 5-10. Paul commands church discipline for unrepentant immorality, warns against lawsuits among believers, teaches that bodies belong to the Lord, gives pastoral counsel on marriage and singleness, and addresses food offered to idols by balancing freedom with love. He concludes: 'Do all to the glory of God.'",
      "word_count": 51
    },
    {
      "type": "context",
      "sequence": 3,
      "audio_script": "Corinth's permissive culture pressured believers to detach faith from bodily and relational ethics.",
      "word_count": 13
    },
    {
      "type": "analysis",
      "sequence": 4,
      "audio_script": "Grace does not minimize holiness; it empowers it. Christian freedom is governed by love and witness. The body is a temple of the Spirit and belongs to Christ.",
      "word_count": 28
    },
    {
      "type": "themes",
      "sequence": 5,
      "audio_script": "Key themes include discipline, purity, sanctified sexuality, covenant faithfulness, conscience, liberty, and God's glory in ordinary life.",
      "word_count": 17
    },
    {
      "type": "question",
      "sequence": 6,
      "audio_script": "Review question: What does Paul say the body of a believer is in 1 Corinthians 6? Answer: a temple of the Holy Spirit who is in you, whom you have from God.",
      "correct_answer": "a temple of the Holy Spirit who is in you — received from God",
      "acceptable_variants": [
        "your body is the holy spirit's temple — you were bought at a price",
        "the body belongs to god because it is where the spirit dwells",
        "1 corinthians 6:19 — the body as the holy spirit's temple"
      ],
      "word_count": 32
    },
    {
      "type": "close",
      "sequence": 7,
      "audio_script": "Holiness is embodied discipleship for God's glory. Next, Paul addresses worship order, spiritual gifts, and resurrection hope.",
      "word_count": 17
    }
  ],
  "metadata": {
    "difficulty": "intermediate",
    "testament": "new",
    "book": "1_corinthians",
    "chapter_range": "5-10",
    "theological_themes": [
      "holiness",
      "discipline",
      "body",
      "freedom",
      "glory_of_god"
    ],
    "time_period": "circa_55_ad",
    "canonical_order": 46
  },
  "vocabulary": [
    {
      "term": "temple of the Holy Spirit",
      "definition": "Paul's teaching in 1 Corinthians 6:19 that the believer's body is the dwelling place of the Spirit; it grounds Christian sexual ethics in theology rather than rules"
    },
    {
      "term": "food sacrificed to idols",
      "definition": "The issue in 1 Corinthians 8-10 about eating meat offered to pagan gods; Paul argues that knowledge must yield to love for the weak brother whose conscience might be damaged"
    }
  ]
}
</file>

<file path="curriculum/courses/new-testament-foundations-06-pauline-epistles/lessons/ntf06_lesson_07.json">
{
  "lesson_id": "ntf06_lesson_07",
  "course_id": "new_testament_foundations_06_pauline_epistles",
  "sequence": 7,
  "title": "1 Corinthians: Worship, Gifts, and Resurrection",
  "objective": "Understand ordered worship, love as the supreme gift, and the centrality of bodily resurrection.",
  "duration": "10 minutes",
  "prerequisite": "ntf06_lesson_06",
  "required_passages": [
    {
      "passage_id": "1co_11_1_16_24",
      "reference": "1 Corinthians 11:1-16:24",
      "text": "As often as you eat this bread and drink the cup, you proclaim the Lord's death... Now you are the body of Christ... If I... have not love, I am nothing... Christ has been raised from the dead... be steadfast... your labor is not in vain."
    }
  ],
  "segments": [
    {
      "type": "orientation",
      "sequence": 1,
      "audio_script": "Paul brings correction to gathered worship and anchors everything in resurrection certainty.",
      "word_count": 12
    },
    {
      "type": "reading",
      "sequence": 2,
      "audio_script": "Listen to 1 Corinthians 11-16. Paul corrects abuse at the Lord's Supper and calls for discernment and unity. He teaches diverse spiritual gifts within one body, placing love above all gifts. He urges orderly worship that edifies all. Finally, he defends Christ's resurrection and the future resurrection of believers, declaring death defeated in Christ.",
      "word_count": 54
    },
    {
      "type": "context",
      "sequence": 3,
      "audio_script": "Corinth prized spiritual display; Paul redirects them toward mutual edification and gospel substance.",
      "word_count": 13
    },
    {
      "type": "analysis",
      "sequence": 4,
      "audio_script": "Love is not optional sentiment but the operating principle of spiritual gifts. Resurrection is non-negotiable: without it, faith collapses; with it, labor has eternal meaning.",
      "word_count": 25
    },
    {
      "type": "themes",
      "sequence": 5,
      "audio_script": "Key themes include Lord's Supper integrity, body unity, spiritual gifts, love, ordered worship, resurrection victory, and steadfast service.",
      "word_count": 18
    },
    {
      "type": "question",
      "sequence": 6,
      "audio_script": "Review question: What does Paul say in 1 Corinthians 15:17 about what would be true if Christ had not been raised? Answer: your faith is futile and you are still in your sins.",
      "correct_answer": "if Christ is not raised your faith is futile and you are still in your sins",
      "acceptable_variants": [
        "faith is empty and sins unforgiven if there is no resurrection",
        "1 corinthians 15 — without resurrection faith is vain and sin remains",
        "paul says the resurrection is essential — without it faith is worthless"
      ],
      "word_count": 33
    },
    {
      "type": "close",
      "sequence": 7,
      "audio_script": "Love governs gifts, and resurrection secures hope. Next we move into 2 Corinthians and ministry through weakness.",
      "word_count": 17
    }
  ],
  "metadata": {
    "difficulty": "intermediate",
    "testament": "new",
    "book": "1_corinthians",
    "chapter_range": "11-16",
    "theological_themes": [
      "worship",
      "spiritual_gifts",
      "love",
      "resurrection",
      "hope"
    ],
    "time_period": "circa_55_ad",
    "canonical_order": 46
  },
  "vocabulary": [
    {
      "term": "resurrection in 1 Corinthians 15",
      "definition": "Paul's extended defense of the bodily resurrection in 1 Corinthians 15; he grounds it in eyewitness testimony, explains the future resurrection body, and declares death defeated through Christ"
    },
    {
      "term": "Lord's Supper in Corinthians",
      "definition": "Paul's correction of the Corinthian practice in 1 Corinthians 11:17-34; some ate and drank to excess while others went hungry — a violation of the body's unity that Paul ties to eating and drinking judgment on oneself"
    }
  ]
}
</file>

<file path="curriculum/courses/new-testament-foundations-06-pauline-epistles/lessons/ntf06_lesson_08.json">
{
  "lesson_id": "ntf06_lesson_08",
  "course_id": "new_testament_foundations_06_pauline_epistles",
  "sequence": 8,
  "title": "2 Corinthians: Comfort in Affliction",
  "objective": "See how God comforts His people and displays gospel ministry through suffering and integrity.",
  "duration": "9 minutes",
  "prerequisite": "ntf06_lesson_07",
  "required_passages": [
    {
      "passage_id": "2co_1_1_4_18",
      "reference": "2 Corinthians 1:1-4:18",
      "text": "The Father of mercies and God of all comfort... we have this treasure in jars of clay, to show that the surpassing power belongs to God... momentary affliction is preparing an eternal weight of glory."
    }
  ],
  "segments": [
    {
      "type": "orientation",
      "sequence": 1,
      "audio_script": "Paul opens 2 Corinthians by reframing suffering as the stage for God's sustaining power.",
      "word_count": 14
    },
    {
      "type": "reading",
      "sequence": 2,
      "audio_script": "Listen to 2 Corinthians 1-4. Paul blesses the God of all comfort who strengthens us in affliction so we can comfort others. He explains his ministry sincerity and dependence on God's promises. He contrasts old and new covenants, proclaiming the Spirit's transforming glory. Though afflicted and pressed, he says believers carry treasure in jars of clay so God's power is seen.",
      "word_count": 61
    },
    {
      "type": "context",
      "sequence": 3,
      "audio_script": "Opponents questioned Paul's credibility because of weakness and hardship.",
      "word_count": 9
    },
    {
      "type": "analysis",
      "sequence": 4,
      "audio_script": "In gospel ministry, weakness is not disqualification but context for divine strength. Authentic leadership values integrity, transparency, and endurance over image.",
      "word_count": 21
    },
    {
      "type": "themes",
      "sequence": 5,
      "audio_script": "Key themes include divine comfort, integrity, new covenant glory, weakness and power, perseverance, and eternal perspective.",
      "word_count": 16
    },
    {
      "type": "question",
      "sequence": 6,
      "audio_script": "Review question: What does Paul say God does with all affliction in 2 Corinthians 1? Answer: God comforts us in all our affliction so that we may be able to comfort those who are in any affliction with the comfort we ourselves receive from God.",
      "correct_answer": "God comforts us in affliction so we can comfort others with the same comfort we received",
      "acceptable_variants": [
        "the comfort we receive from god equips us to comfort others in their trials",
        "god comforts in suffering so we can pass that comfort to those who suffer",
        "2 corinthians 1 — suffering and comfort are both shared with others through christ"
      ],
      "word_count": 45
    },
    {
      "type": "close",
      "sequence": 7,
      "audio_script": "God comforts and strengthens servants in affliction. Next, Paul calls for holiness, generosity, and boast only in the Lord.",
      "word_count": 19
    }
  ],
  "metadata": {
    "difficulty": "intermediate",
    "testament": "new",
    "book": "2_corinthians",
    "chapter_range": "1-4",
    "theological_themes": [
      "comfort",
      "suffering",
      "integrity",
      "new_covenant",
      "power_in_weakness"
    ],
    "time_period": "circa_56_ad",
    "canonical_order": 47
  },
  "vocabulary": [
    {
      "term": "thorn in the flesh",
      "definition": "Paul's unidentified affliction in 2 Corinthians 12:7-10; God refused to remove it so that his power would be made perfect in weakness — the basis for Paul's contentment in suffering"
    },
    {
      "term": "treasury of weakness",
      "definition": "Paul's perspective in 2 Corinthians 4:7 — we have this treasure in jars of clay so the surpassing power belongs to God; weakness makes God's power more visible not less"
    }
  ]
}
</file>

<file path="curriculum/courses/new-testament-foundations-06-pauline-epistles/lessons/ntf06_lesson_09.json">
{
  "lesson_id": "ntf06_lesson_09",
  "course_id": "new_testament_foundations_06_pauline_epistles",
  "sequence": 9,
  "title": "2 Corinthians: Reconciliation and Generosity",
  "objective": "Embrace reconciliation with God and practical generosity flowing from grace.",
  "duration": "9 minutes",
  "prerequisite": "ntf06_lesson_08",
  "required_passages": [
    {
      "passage_id": "2co_5_1_9_15",
      "reference": "2 Corinthians 5:1-9:15",
      "text": "If anyone is in Christ, he is a new creation... God... gave us the ministry of reconciliation... For our sake he made him to be sin who knew no sin... God loves a cheerful giver."
    }
  ],
  "segments": [
    {
      "type": "orientation",
      "sequence": 1,
      "audio_script": "Paul links gospel reconciliation to relational restoration and financial generosity.",
      "word_count": 10
    },
    {
      "type": "reading",
      "sequence": 2,
      "audio_script": "Listen to 2 Corinthians 5-9. Paul describes believers as ambassadors of reconciliation: God in Christ reconciling the world to Himself. He appeals for transformed holiness and restored relationships. He then organizes relief for needy believers, presenting giving as grace, willing joy, and worshipful partnership.",
      "word_count": 44
    },
    {
      "type": "context",
      "sequence": 3,
      "audio_script": "Corinth needed both relational repair with Paul and tangible participation in support for suffering churches.",
      "word_count": 15
    },
    {
      "type": "analysis",
      "sequence": 4,
      "audio_script": "The cross creates new identity and mission. Reconciled people become reconciling people. Generosity is not coercion but gospel-shaped gratitude and trust in God's provision.",
      "word_count": 24
    },
    {
      "type": "themes",
      "sequence": 5,
      "audio_script": "Key themes include new creation, substitutionary atonement, ministry of reconciliation, holiness, grace giving, and kingdom partnership.",
      "word_count": 16
    },
    {
      "type": "question",
      "sequence": 6,
      "audio_script": "Review question: What does Paul say about the ministry of reconciliation in 2 Corinthians 5? Answer: God reconciled us to himself through Christ and gave us the ministry of reconciliation — we are ambassadors for Christ, imploring people to be reconciled to God.",
      "correct_answer": "God reconciled us through Christ and gave us the ministry of reconciliation as his ambassadors",
      "acceptable_variants": [
        "we are ambassadors begging people on christ's behalf to be reconciled to god",
        "god initiated reconciliation and made us its ministers and messengers",
        "2 corinthians 5 — reconciliation through christ, ambassadors imploring the world"
      ],
      "word_count": 43
    },
    {
      "type": "close",
      "sequence": 7,
      "audio_script": "Reconciled by grace, we live and give differently. Next, Paul defends apostolic authority through weakness and Christ's strength.",
      "word_count": 18
    }
  ],
  "metadata": {
    "difficulty": "intermediate",
    "testament": "new",
    "book": "2_corinthians",
    "chapter_range": "5-9",
    "theological_themes": [
      "reconciliation",
      "new_creation",
      "atonement",
      "generosity",
      "mission"
    ],
    "time_period": "circa_56_ad",
    "canonical_order": 47
  },
  "vocabulary": [
    {
      "term": "reconciliation",
      "definition": "The restoration of a broken relationship; Paul uses it in 2 Corinthians 5 for God's act in Christ of removing the enmity between God and humanity, making peace through the cross"
    },
    {
      "term": "new creation",
      "definition": "Paul's declaration in 2 Corinthians 5:17 — if anyone is in Christ, he is a new creation; the old has gone and the new has come — union with Christ marks the beginning of the new age"
    }
  ]
}
</file>

<file path="curriculum/courses/new-testament-foundations-06-pauline-epistles/lessons/ntf06_lesson_10.json">
{
  "lesson_id": "ntf06_lesson_10",
  "course_id": "new_testament_foundations_06_pauline_epistles",
  "sequence": 10,
  "title": "2 Corinthians: Strength in Weakness",
  "objective": "Understand Paul's defense of true ministry and Christ's power perfected in weakness.",
  "duration": "9 minutes",
  "prerequisite": "ntf06_lesson_09",
  "required_passages": [
    {
      "passage_id": "2co_10_1_13_14",
      "reference": "2 Corinthians 10:1-13:14",
      "text": "The weapons of our warfare are not of the flesh... My grace is sufficient for you, for my power is made perfect in weakness... Examine yourselves, to see whether you are in the faith."
    }
  ],
  "segments": [
    {
      "type": "orientation",
      "sequence": 1,
      "audio_script": "Paul counters false apostles by redefining authority around cross-shaped weakness and truth.",
      "word_count": 12
    },
    {
      "type": "reading",
      "sequence": 2,
      "audio_script": "Listen to 2 Corinthians 10-13. Paul rejects worldly boasting and insists ministry warfare is spiritual. He exposes deceptive teachers and recounts hardships, visions, and his thorn in the flesh. The Lord answers, 'My grace is sufficient for you.' Paul therefore boasts in weaknesses so Christ's power may rest on him. He closes by calling the church to self-examination and restoration.",
      "word_count": 60
    },
    {
      "type": "context",
      "sequence": 3,
      "audio_script": "In Corinth, charismatic self-promotion threatened gospel integrity and church discernment.",
      "word_count": 10
    },
    {
      "type": "analysis",
      "sequence": 4,
      "audio_script": "True apostolic ministry is cruciform: marked by truth, sacrifice, and dependence. Weakness keeps servants near grace and highlights Christ's sufficiency.",
      "word_count": 20
    },
    {
      "type": "themes",
      "sequence": 5,
      "audio_script": "Key themes include spiritual warfare, discernment, false teachers, sufficiency of grace, power in weakness, and self-examination.",
      "word_count": 16
    },
    {
      "type": "question",
      "sequence": 6,
      "audio_script": "Review question: What does Paul say about himself in 2 Corinthians 12:9-10 about boasting in weaknesses? Answer: he will boast in his weaknesses so that Christ's power may rest on him; when he is weak, then he is strong.",
      "correct_answer": "he boasts in weaknesses so Christ's power rests on him — when weak, then strong",
      "acceptable_variants": [
        "I will boast in weakness because power is made perfect in weakness",
        "Paul's paradox — strength through weakness when christ's power is the source",
        "2 corinthians 12 — weakness is the condition for christ's power"
      ],
      "word_count": 39
    },
    {
      "type": "close",
      "sequence": 7,
      "audio_script": "Christ's power is perfected in weakness. Next we turn to Galatians and the defense of grace against legalism.",
      "word_count": 18
    }
  ],
  "metadata": {
    "difficulty": "intermediate",
    "testament": "new",
    "book": "2_corinthians",
    "chapter_range": "10-13",
    "theological_themes": [
      "weakness",
      "grace",
      "authority",
      "discernment",
      "perseverance"
    ],
    "time_period": "circa_56_ad",
    "canonical_order": 47
  },
  "vocabulary": [
    {
      "term": "super-apostles",
      "definition": "Paul's sarcastic label in 2 Corinthians 11 for the rival preachers who boasted in status, eloquence, and signs; Paul counters by boasting in his sufferings rather than achievements"
    },
    {
      "term": "power made perfect in weakness",
      "definition": "God's response to Paul's prayer about the thorn in 2 Corinthians 12:9 — divine strength operates through human limitation, making God's glory undeniable"
    }
  ]
}
</file>

<file path="curriculum/courses/new-testament-foundations-06-pauline-epistles/lessons/ntf06_lesson_11.json">
{
  "lesson_id": "ntf06_lesson_11",
  "course_id": "new_testament_foundations_06_pauline_epistles",
  "sequence": 11,
  "title": "Galatians: No Other Gospel",
  "objective": "Defend justification by faith against legalism and understand Christian freedom in Christ.",
  "duration": "9 minutes",
  "prerequisite": "ntf06_lesson_10",
  "required_passages": [
    {
      "passage_id": "gal_1_1_3_29",
      "reference": "Galatians 1:1-3:29",
      "text": "If anyone is preaching to you a gospel contrary... let him be accursed... a person is not justified by works of the law but through faith in Jesus Christ... The righteous shall live by faith."
    }
  ],
  "segments": [
    {
      "type": "orientation",
      "sequence": 1,
      "audio_script": "Galatians is Paul's urgent defense of grace against distortion.",
      "word_count": 9
    },
    {
      "type": "reading",
      "sequence": 2,
      "audio_script": "Listen to Galatians 1-3. Paul rebukes the churches for deserting the true gospel. He recounts his apostolic call and confrontation with Peter to preserve gospel truth. He insists justification is by faith in Christ, not law works. Abraham's example and Christ's redeeming curse-bearing work confirm this.",
      "word_count": 46
    },
    {
      "type": "context",
      "sequence": 3,
      "audio_script": "False teachers pressured Gentiles to adopt Jewish law markers as conditions of full belonging.",
      "word_count": 14
    },
    {
      "type": "analysis",
      "sequence": 4,
      "audio_script": "Any addition to grace creates another gospel. Faith unites believers to Christ and Abraham's promise, forming one family beyond ethnic barriers.",
      "word_count": 21
    },
    {
      "type": "themes",
      "sequence": 5,
      "audio_script": "Key themes include gospel purity, justification by faith, apostolic authority, promise over law, and unity in Christ.",
      "word_count": 17
    },
    {
      "type": "question",
      "sequence": 6,
      "audio_script": "Review question: What does Paul say about the relationship between faith and the law in Galatians 3? Answer: the law is not opposed to the promises of God but was a guardian until Christ came, so that we could be justified by faith.",
      "correct_answer": "the law was a guardian until Christ came — now justification is by faith, not the law",
      "acceptable_variants": [
        "the law served as a tutor leading to Christ — faith has come and we are no longer under the guardian",
        "galatians 3 — the law imprisoned us until faith in christ arrived",
        "the law's role as guardian ended when faith in christ fulfilled its purpose"
      ],
      "word_count": 43
    },
    {
      "type": "close",
      "sequence": 7,
      "audio_script": "Christ alone justifies. Next, we explore freedom, Spirit fruit, and practical life in Galatians 4-6.",
      "word_count": 15
    }
  ],
  "metadata": {
    "difficulty": "intermediate",
    "testament": "new",
    "book": "galatians",
    "chapter_range": "1-3",
    "theological_themes": [
      "grace",
      "justification",
      "faith",
      "gospel"
    ],
    "time_period": "circa_49_ad",
    "canonical_order": 48
  },
  "vocabulary": [
    {
      "term": "justification by faith alone",
      "definition": "Paul's central argument in Galatians 2-3 — no one is justified by works of the law but by faith in Jesus Christ; this is the theological heart of the Reformation's sola fide"
    },
    {
      "term": "guardian",
      "definition": "The Greek paidagogos in Galatians 3:24, often translated tutor or schoolmaster; a slave who escorted children to school and maintained discipline — Paul uses it for the law's role before Christ came"
    }
  ]
}
</file>

<file path="curriculum/courses/new-testament-foundations-06-pauline-epistles/lessons/ntf06_lesson_12.json">
{
  "lesson_id": "ntf06_lesson_12",
  "course_id": "new_testament_foundations_06_pauline_epistles",
  "sequence": 12,
  "title": "Galatians: Freedom by the Spirit",
  "objective": "Live out Christian freedom through love, Spirit-led holiness, and restored community.",
  "duration": "9 minutes",
  "prerequisite": "ntf06_lesson_11",
  "required_passages": [
    {
      "passage_id": "gal_4_1_6_18",
      "reference": "Galatians 4:1-6:18",
      "text": "For freedom Christ has set us free... Walk by the Spirit, and you will not gratify the desires of the flesh... the fruit of the Spirit is love, joy, peace... Bear one another's burdens."
    }
  ],
  "segments": [
    {
      "type": "orientation",
      "sequence": 1,
      "audio_script": "Freedom in Christ is not self-rule but Spirit-enabled love.",
      "word_count": 9
    },
    {
      "type": "reading",
      "sequence": 2,
      "audio_script": "Listen to Galatians 4-6. Paul contrasts slavery and sonship, urges believers not to return to law bondage, and commands: 'Walk by the Spirit.' He lists works of the flesh and fruit of the Spirit, calling the church to gentleness, burden-bearing, and sowing to the Spirit.",
      "word_count": 45
    },
    {
      "type": "context",
      "sequence": 3,
      "audio_script": "Galatian churches needed practical guidance to avoid both legalism and license.",
      "word_count": 11
    },
    {
      "type": "analysis",
      "sequence": 4,
      "audio_script": "Gospel freedom produces transformed character and communal care. The Spirit forms Christlike life that law cannot manufacture.",
      "word_count": 17
    },
    {
      "type": "themes",
      "sequence": 5,
      "audio_script": "Key themes include adoption, freedom, Spirit-led sanctification, fruit of the Spirit, mutual restoration, and new creation.",
      "word_count": 16
    },
    {
      "type": "question",
      "sequence": 6,
      "audio_script": "Review question: What is the fruit of the Spirit listed by Paul in Galatians 5? Answer: love, joy, peace, patience, kindness, goodness, faithfulness, gentleness, and self-control.",
      "correct_answer": "love, joy, peace, patience, kindness, goodness, faithfulness, gentleness, and self-control",
      "acceptable_variants": [
        "the ninefold fruit of the spirit from galatians 5:22-23",
        "love joy peace patience kindness goodness faithfulness gentleness self-control",
        "galatians 5 — nine qualities produced by the spirit's work in the believer"
      ],
      "word_count": 26
    },
    {
      "type": "close",
      "sequence": 7,
      "audio_script": "True freedom bears Spirit fruit and serves others in love. Next, Ephesians unveils God's cosmic plan in Christ.",
      "word_count": 18
    }
  ],
  "metadata": {
    "difficulty": "intermediate",
    "testament": "new",
    "book": "galatians",
    "chapter_range": "4-6",
    "theological_themes": [
      "freedom",
      "holy_spirit",
      "fruit",
      "sanctification",
      "community"
    ],
    "time_period": "circa_49_ad",
    "canonical_order": 48
  },
  "vocabulary": [
    {
      "term": "fruit of the Spirit",
      "definition": "The nine qualities listed in Galatians 5:22-23 produced by the Holy Spirit in the believer; described as singular fruit — a unified character rather than nine separate achievements"
    },
    {
      "term": "works of the flesh",
      "definition": "The contrasting list in Galatians 5:19-21 of acts produced by sinful human nature; Paul lists fifteen vices to contrast with the Spirit's fruit, framing the Christian life as a choice between two powers"
    }
  ]
}
</file>

<file path="curriculum/courses/new-testament-foundations-06-pauline-epistles/lessons/ntf06_lesson_13.json">
{
  "lesson_id": "ntf06_lesson_13",
  "course_id": "new_testament_foundations_06_pauline_epistles",
  "sequence": 13,
  "title": "Ephesians: Identity in Christ",
  "objective": "Celebrate God's saving plan and the church's new identity as one body in Christ.",
  "duration": "9 minutes",
  "prerequisite": "ntf06_lesson_12",
  "required_passages": [
    {
      "passage_id": "eph_1_1_3_21",
      "reference": "Ephesians 1:1-3:21",
      "text": "He chose us in him... by grace you have been saved through faith... He himself is our peace... through the church the manifold wisdom of God might now be made known."
    }
  ],
  "segments": [
    {
      "type": "orientation",
      "sequence": 1,
      "audio_script": "Ephesians opens with worshipful theology of grace, unity, and God's eternal purpose.",
      "word_count": 12
    },
    {
      "type": "reading",
      "sequence": 2,
      "audio_script": "Listen to Ephesians 1-3. Paul blesses God for election, redemption, and sealing by the Spirit. He reminds believers they were dead in sin but made alive by grace through faith. In Christ, Jew and Gentile are reconciled into one new humanity. Paul prays believers grasp Christ's immeasurable love.",
      "word_count": 48
    },
    {
      "type": "context",
      "sequence": 3,
      "audio_script": "Likely a circular letter, Ephesians gives a panoramic vision of salvation and church identity.",
      "word_count": 14
    },
    {
      "type": "analysis",
      "sequence": 4,
      "audio_script": "Identity precedes activity. The church is not an optional add-on but the display of God's wisdom. Grace destroys hostility and forms reconciled community.",
      "word_count": 23
    },
    {
      "type": "themes",
      "sequence": 5,
      "audio_script": "Key themes include election, grace, union with Christ, reconciliation, church unity, Spirit sealing, and doxology.",
      "word_count": 15
    },
    {
      "type": "question",
      "sequence": 6,
      "audio_script": "Review question: What does Paul say believers were before God made them alive in Ephesians 2? Answer: dead in trespasses and sins, following the prince of the power of the air, and by nature children of wrath.",
      "correct_answer": "dead in trespasses and sins, following Satan, and children of wrath by nature",
      "acceptable_variants": [
        "dead in sin and following the spirit of disobedience — children of wrath",
        "ephesians 2 describes the pre-conversion state as spiritual death under satanic influence",
        "dead in sin, subject to satan, and deserving wrath — before God's grace intervened"
      ],
      "word_count": 37
    },
    {
      "type": "close",
      "sequence": 7,
      "audio_script": "Saved by grace, we become one people in Christ. Next, Ephesians calls believers to worthy living and spiritual warfare.",
      "word_count": 19
    }
  ],
  "metadata": {
    "difficulty": "intermediate",
    "testament": "new",
    "book": "ephesians",
    "chapter_range": "1-3",
    "theological_themes": [
      "grace",
      "identity",
      "church",
      "unity",
      "reconciliation"
    ],
    "time_period": "circa_60_ad",
    "canonical_order": 49
  },
  "vocabulary": [
    {
      "term": "dead in sin",
      "definition": "Paul's description in Ephesians 2:1 of human spiritual condition before salvation; not injured or weakened but dead — requiring divine resurrection, not human effort"
    },
    {
      "term": "body of Christ",
      "definition": "Paul's image in Ephesians 4 for the church as Christ's body with Christ as head; every member has a role and the whole body grows together in love"
    }
  ]
}
</file>

<file path="curriculum/courses/new-testament-foundations-06-pauline-epistles/lessons/ntf06_lesson_14.json">
{
  "lesson_id": "ntf06_lesson_14",
  "course_id": "new_testament_foundations_06_pauline_epistles",
  "sequence": 14,
  "title": "Ephesians: Walk Worthy",
  "objective": "Practice gospel-shaped relationships and stand firm with the armor of God.",
  "duration": "9 minutes",
  "prerequisite": "ntf06_lesson_13",
  "required_passages": [
    {
      "passage_id": "eph_4_1_6_24",
      "reference": "Ephesians 4:1-6:24",
      "text": "Walk in a manner worthy... put on the new self... be imitators of God... submit to one another... put on the whole armor of God... stand firm."
    }
  ],
  "segments": [
    {
      "type": "orientation",
      "sequence": 1,
      "audio_script": "Paul turns from theology to practice: how redeemed people walk together and resist evil.",
      "word_count": 14
    },
    {
      "type": "reading",
      "sequence": 2,
      "audio_script": "Listen to Ephesians 4-6. Paul urges humility, patience, and unity in the Spirit. He calls believers to put off the old self and put on the new. He applies gospel ethics to speech, sexuality, work, family, and mutual submission. He concludes with the armor of God and persistent prayer in spiritual warfare.",
      "word_count": 52
    },
    {
      "type": "context",
      "sequence": 3,
      "audio_script": "Household and social structures are transformed not by domination but by Christlike love and service.",
      "word_count": 15
    },
    {
      "type": "analysis",
      "sequence": 4,
      "audio_script": "Sanctification is communal and practical. Spiritual warfare is resisted through truth, righteousness, faith, Scripture, and prayer—not worldly methods.",
      "word_count": 18
    },
    {
      "type": "themes",
      "sequence": 5,
      "audio_script": "Key themes include worthy walk, new self, holy relationships, unity, spiritual warfare, and persevering prayer.",
      "word_count": 15
    },
    {
      "type": "question",
      "sequence": 6,
      "audio_script": "Review question: What is the armor of God that Paul describes in Ephesians 6? Answer: the belt of truth, breastplate of righteousness, feet fitted with the gospel of peace, shield of faith, helmet of salvation, and sword of the Spirit which is the word of God.",
      "correct_answer": "belt of truth, breastplate of righteousness, gospel of peace, shield of faith, helmet of salvation, and sword of the Spirit",
      "acceptable_variants": [
        "the six pieces of armor in ephesians 6 — truth righteousness gospel faith salvation and the word",
        "the full armor of god: truth belt, righteousness breastplate, peace shoes, faith shield, salvation helmet, word sword",
        "ephesians 6:14-17 — the complete armor for standing against spiritual forces"
      ],
      "word_count": 46
    },
    {
      "type": "close",
      "sequence": 7,
      "audio_script": "The gospel reshapes life and equips us to stand. Next, Philippians teaches joy and humility in Christ.",
      "word_count": 17
    }
  ],
  "metadata": {
    "difficulty": "intermediate",
    "testament": "new",
    "book": "ephesians",
    "chapter_range": "4-6",
    "theological_themes": [
      "sanctification",
      "unity",
      "relationships",
      "armor_of_god",
      "prayer"
    ],
    "time_period": "circa_60_ad",
    "canonical_order": 49
  },
  "vocabulary": [
    {
      "term": "armor of God",
      "definition": "Paul's metaphor in Ephesians 6:10-18 for the spiritual resources available to believers in the cosmic conflict against evil; the imagery draws on Isaiah 59 where God himself wears armor"
    },
    {
      "term": "principalities and powers",
      "definition": "Paul's terms in Ephesians 6:12 for the spiritual forces behind human opposition; the Christian's struggle is not merely human but involves cosmic evil requiring divine armor"
    }
  ]
}
</file>

<file path="curriculum/courses/new-testament-foundations-06-pauline-epistles/lessons/ntf06_lesson_15.json">
{
  "lesson_id": "ntf06_lesson_15",
  "course_id": "new_testament_foundations_06_pauline_epistles",
  "sequence": 15,
  "title": "Philippians: Joy in Christ",
  "objective": "Learn gospel joy in suffering and unity through Christ's humility.",
  "duration": "9 minutes",
  "prerequisite": "ntf06_lesson_14",
  "required_passages": [
    {
      "passage_id": "php_1_1_2_30",
      "reference": "Philippians 1:1-2:30",
      "text": "To live is Christ, and to die is gain... complete my joy by being of the same mind... Christ Jesus... humbled himself... therefore God has highly exalted him."
    }
  ],
  "segments": [
    {
      "type": "orientation",
      "sequence": 1,
      "audio_script": "From prison, Paul writes one of Scripture's most joyful letters.",
      "word_count": 10
    },
    {
      "type": "reading",
      "sequence": 2,
      "audio_script": "Listen to Philippians 1-2. Paul rejoices that the gospel advances even through chains. He says, 'To live is Christ, and to die is gain.' He urges the church to unity and presents Christ's humility: though equal with God, He took servant form and obeyed to death on a cross; therefore God exalted Him.",
      "word_count": 53
    },
    {
      "type": "context",
      "sequence": 3,
      "audio_script": "Philippi was a supportive church, yet threatened by relational tensions and external pressure.",
      "word_count": 13
    },
    {
      "type": "analysis",
      "sequence": 4,
      "audio_script": "Christian joy is rooted in Christ's lordship, not circumstances. Unity grows where humility and self-giving love replace rivalry.",
      "word_count": 18
    },
    {
      "type": "themes",
      "sequence": 5,
      "audio_script": "Key themes include joy in suffering, gospel partnership, Christ's humiliation and exaltation, unity, and faithful witness.",
      "word_count": 16
    },
    {
      "type": "question",
      "sequence": 6,
      "audio_script": "Review question: What does Paul describe as his one ambition and driving purpose in Philippians 1? Answer: that Christ will be honored in his body whether by life or by death — for to him to live is Christ and to die is gain.",
      "correct_answer": "that Christ be honored in his body whether by life or death — to live is Christ and to die is gain",
      "acceptable_variants": [
        "his purpose is christ being magnified in his body — living or dying",
        "philippians 1 — for me to live is christ to die is gain",
        "whether he lives or dies paul wants christ exalted in him"
      ],
      "word_count": 44
    },
    {
      "type": "close",
      "sequence": 7,
      "audio_script": "Joy and humility flourish under Christ's lordship. Next, Philippians 3-4 calls us to mature pursuit and prayerful peace.",
      "word_count": 18
    }
  ],
  "metadata": {
    "difficulty": "intermediate",
    "testament": "new",
    "book": "philippians",
    "chapter_range": "1-2",
    "theological_themes": [
      "joy",
      "humility",
      "christ_hymn",
      "unity",
      "suffering"
    ],
    "time_period": "circa_61_ad",
    "canonical_order": 50
  },
  "vocabulary": [
    {
      "term": "to live is Christ",
      "definition": "Paul's autobiographical statement in Philippians 1:21 expressing that his entire existence is defined by and for Christ; dying brings gain because it means being with Christ"
    },
    {
      "term": "Philippians as prison letter",
      "definition": "Philippians was written by Paul during imprisonment, likely in Rome; despite his chains he writes a letter overflowing with joy — demonstrating that circumstances do not determine contentment"
    }
  ]
}
</file>

<file path="curriculum/courses/new-testament-foundations-06-pauline-epistles/lessons/ntf06_lesson_16.json">
{
  "lesson_id": "ntf06_lesson_16",
  "course_id": "new_testament_foundations_06_pauline_epistles",
  "sequence": 16,
  "title": "Philippians: Press On",
  "objective": "Pursue Christ-centered maturity, contentment, and prayerful peace.",
  "duration": "9 minutes",
  "prerequisite": "ntf06_lesson_15",
  "required_passages": [
    {
      "passage_id": "php_3_1_4_23",
      "reference": "Philippians 3:1-4:23",
      "text": "I count everything as loss because of the surpassing worth of knowing Christ Jesus... I press on... Rejoice in the Lord always... do not be anxious about anything... I can do all things through him who strengthens me."
    }
  ],
  "segments": [
    {
      "type": "orientation",
      "sequence": 1,
      "audio_script": "Paul calls believers to leave self-righteousness behind and pursue Christ with steady joy.",
      "word_count": 13
    },
    {
      "type": "reading",
      "sequence": 2,
      "audio_script": "Listen to Philippians 3-4. Paul rejects confidence in fleshly credentials and counts all things loss for Christ. He presses on toward the goal of knowing Him fully. He urges believers to rejoice always, pray instead of panic, think on what is true and excellent, and learn contentment in every circumstance through Christ's strength.",
      "word_count": 53
    },
    {
      "type": "context",
      "sequence": 3,
      "audio_script": "The church needed stability amid pressure, false confidence, and anxiety.",
      "word_count": 10
    },
    {
      "type": "analysis",
      "sequence": 4,
      "audio_script": "Maturity is directional: pressing on in grace. Peace flows from prayerful dependence and disciplined thought. Contentment is Christ-enabled, not circumstance-produced.",
      "word_count": 20
    },
    {
      "type": "themes",
      "sequence": 5,
      "audio_script": "Key themes include knowing Christ, resurrection hope, spiritual maturity, anxiety and prayer, contentment, and generosity.",
      "word_count": 15
    },
    {
      "type": "question",
      "sequence": 6,
      "audio_script": "Review question: What does Paul say about his attitude toward circumstances in Philippians 4:11? Answer: he has learned, in whatever state he is, to be content — whether abased or abounding.",
      "correct_answer": "he has learned contentment in all circumstances — whether abased or abounding",
      "acceptable_variants": [
        "I have learned to be content in all situations",
        "philippians 4 — contentment in abundance and in need has been learned not given",
        "paul says he knows how to be brought low and how to abound — contentment is learned"
      ],
      "word_count": 31
    },
    {
      "type": "close",
      "sequence": 7,
      "audio_script": "Press on in Christ with joy and peace. Next, Colossians magnifies Christ's supremacy over all rival powers.",
      "word_count": 17
    }
  ],
  "metadata": {
    "difficulty": "intermediate",
    "testament": "new",
    "book": "philippians",
    "chapter_range": "3-4",
    "theological_themes": [
      "discipleship",
      "contentment",
      "prayer",
      "peace",
      "perseverance"
    ],
    "time_period": "circa_61_ad",
    "canonical_order": 50
  },
  "vocabulary": [
    {
      "term": "Christ-hymn",
      "definition": "The poem in Philippians 2:6-11 describing Christ's humiliation (emptying himself, taking servant form) and exaltation (name above all names); it grounds the call to humble others-focused living"
    },
    {
      "term": "I can do all things through Christ",
      "definition": "Philippians 4:13 in context — not a general promise of ability but Paul's testimony that Christ strengthens him to face both abundance and need with contentment"
    }
  ]
}
</file>

<file path="curriculum/courses/new-testament-foundations-06-pauline-epistles/lessons/ntf06_lesson_17.json">
{
  "lesson_id": "ntf06_lesson_17",
  "course_id": "new_testament_foundations_06_pauline_epistles",
  "sequence": 17,
  "title": "Colossians: Christ Supreme",
  "objective": "Exalt the supremacy of Christ over creation, redemption, and every competing philosophy.",
  "duration": "9 minutes",
  "prerequisite": "ntf06_lesson_16",
  "required_passages": [
    {
      "passage_id": "col_1_1_2_23",
      "reference": "Colossians 1:1-2:23",
      "text": "He is the image of the invisible God... all things were created through him and for him... in him all the fullness of God was pleased to dwell... in Christ are hidden all the treasures of wisdom and knowledge."
    }
  ],
  "segments": [
    {
      "type": "orientation",
      "sequence": 1,
      "audio_script": "Colossians centers everything on Christ's unmatched supremacy.",
      "word_count": 7
    },
    {
      "type": "reading",
      "sequence": 2,
      "audio_script": "Listen to Colossians 1-2. Paul thanks God for gospel fruit and prays for spiritual wisdom. He presents Christ as Creator, Sustainer, Head of the church, and Reconciler by His cross. He warns against empty philosophy, legalism, and mystical additions, declaring believers complete in Christ.",
      "word_count": 44
    },
    {
      "type": "context",
      "sequence": 3,
      "audio_script": "Colossae faced syncretistic teaching that diminished Christ by adding spiritual formulas and regulations.",
      "word_count": 13
    },
    {
      "type": "analysis",
      "sequence": 4,
      "audio_script": "If Christ is supreme and sufficient, believers need no supplemental spirituality. Growth comes by continuing in Christ, rooted and built up in Him.",
      "word_count": 23
    },
    {
      "type": "themes",
      "sequence": 5,
      "audio_script": "Key themes include Christology, reconciliation, gospel growth, discernment, fullness in Christ, and freedom from legalism.",
      "word_count": 15
    },
    {
      "type": "question",
      "sequence": 6,
      "audio_script": "Review question: What is the Christ-hymn in Colossians 1:15-20 about? Answer: it describes Christ as the image of the invisible God, firstborn over all creation, through whom all things were created and in whom all things hold together.",
      "correct_answer": "Christ is the image of God, firstborn over creation, creator and sustainer of all things",
      "acceptable_variants": [
        "colossians 1 — christ is the image of god and the agent of creation and redemption",
        "he is before all things and in him all things hold together — the pre-eminent one",
        "the colossian hymn: christ as creator, sustainer, and head of the church"
      ],
      "word_count": 38
    },
    {
      "type": "close",
      "sequence": 7,
      "audio_script": "Christ is fully sufficient. Next, Paul applies this supremacy to holy living and witness.",
      "word_count": 14
    }
  ],
  "metadata": {
    "difficulty": "intermediate",
    "testament": "new",
    "book": "colossians",
    "chapter_range": "1-2",
    "theological_themes": [
      "supremacy_of_christ",
      "sufficiency",
      "reconciliation",
      "discernment"
    ],
    "time_period": "circa_60_ad",
    "canonical_order": 51
  },
  "vocabulary": [
    {
      "term": "image of the invisible God",
      "definition": "Paul's description of Christ in Colossians 1:15 — not a copy but the exact representation; to see Christ is to see what God is like"
    },
    {
      "term": "head of the body",
      "definition": "Paul's image in Colossians 1:18 for Christ's relationship to the church; Christ is the source of life and direction for the body — the church as organism depends on him for everything"
    }
  ]
}
</file>

<file path="curriculum/courses/new-testament-foundations-06-pauline-epistles/lessons/ntf06_lesson_18.json">
{
  "lesson_id": "ntf06_lesson_18",
  "course_id": "new_testament_foundations_06_pauline_epistles",
  "sequence": 18,
  "title": "Colossians: New Self Living",
  "objective": "Practice putting off the old self and putting on Christlike virtues in home and public life.",
  "duration": "9 minutes",
  "prerequisite": "ntf06_lesson_17",
  "required_passages": [
    {
      "passage_id": "col_3_1_4_18",
      "reference": "Colossians 3:1-4:18",
      "text": "Set your minds on things that are above... put to death what is earthly... put on compassionate hearts... whatever you do... do everything in the name of the Lord Jesus."
    }
  ],
  "segments": [
    {
      "type": "orientation",
      "sequence": 1,
      "audio_script": "Union with Christ produces practical transformation in speech, relationships, and work.",
      "word_count": 11
    },
    {
      "type": "reading",
      "sequence": 2,
      "audio_script": "Listen to Colossians 3-4. Paul tells believers to seek things above because they have died and risen with Christ. They must put to death sin and put on compassion, humility, patience, forgiveness, and love. He applies this to households, work, and prayerful witness toward outsiders.",
      "word_count": 45
    },
    {
      "type": "context",
      "sequence": 3,
      "audio_script": "Colossian believers needed a clear path from doctrine to daily discipleship.",
      "word_count": 11
    },
    {
      "type": "analysis",
      "sequence": 4,
      "audio_script": "Sanctification is identity-driven: become what you are in Christ. Mission credibility grows where speech and relationships reflect gospel character.",
      "word_count": 19
    },
    {
      "type": "themes",
      "sequence": 5,
      "audio_script": "Key themes include new self, holiness, forgiveness, Christ-centered households, vocational faithfulness, prayer, and witness.",
      "word_count": 14
    },
    {
      "type": "question",
      "sequence": 6,
      "audio_script": "Review question: What does Paul tell the Colossians to put on in Colossians 3? Answer: compassion, kindness, humility, meekness, and patience, bearing with one another and forgiving each other. Over all these put on love.",
      "correct_answer": "compassion, kindness, humility, meekness, patience, bearing with one another, forgiving, and love above all",
      "acceptable_variants": [
        "put on the new self: compassion kindness humility meekness patience — and over all love",
        "colossians 3 — the new self is clothed in christ-like virtues with love as the outermost garment",
        "bearing with and forgiving one another and binding all together in love"
      ],
      "word_count": 35
    },
    {
      "type": "close",
      "sequence": 7,
      "audio_script": "The risen life reshapes everything. Next, Thessalonians teaches hope and endurance under pressure.",
      "word_count": 13
    }
  ],
  "metadata": {
    "difficulty": "intermediate",
    "testament": "new",
    "book": "colossians",
    "chapter_range": "3-4",
    "theological_themes": [
      "sanctification",
      "new_self",
      "household_ethics",
      "prayer",
      "witness"
    ],
    "time_period": "circa_60_ad",
    "canonical_order": 51
  },
  "vocabulary": [
    {
      "term": "household code",
      "definition": "The instructions in Colossians 3:18-4:1 for wives, husbands, children, fathers, slaves, and masters; Paul structures relationships within the existing social order while reframing them around Christ"
    },
    {
      "term": "fullness of God in Christ",
      "definition": "The teaching in Colossians 2:9-10 that all the fullness of deity dwells bodily in Christ and believers are complete in him; it refutes any claim that supplementary wisdom or practices are needed"
    }
  ]
}
</file>

<file path="curriculum/courses/new-testament-foundations-06-pauline-epistles/lessons/ntf06_lesson_19.json">
{
  "lesson_id": "ntf06_lesson_19",
  "course_id": "new_testament_foundations_06_pauline_epistles",
  "sequence": 19,
  "title": "1 Thessalonians: Faithful Awaiting",
  "objective": "Encourage holy endurance and hope in Christ's return amid affliction.",
  "duration": "9 minutes",
  "prerequisite": "ntf06_lesson_18",
  "required_passages": [
    {
      "passage_id": "1th_1_1_3_13",
      "reference": "1 Thessalonians 1:1-3:13",
      "text": "Your work of faith and labor of love and steadfastness of hope... you turned to God from idols... to wait for his Son from heaven."
    }
  ],
  "segments": [
    {
      "type": "orientation",
      "sequence": 1,
      "audio_script": "Paul affirms a young church persevering through suffering with vibrant hope.",
      "word_count": 11
    },
    {
      "type": "reading",
      "sequence": 2,
      "audio_script": "Listen to 1 Thessalonians 1-3. Paul thanks God for their faith, love, and hope. They turned from idols to serve the living God and await Jesus from heaven. Despite persecution, they became examples to other believers. Paul expresses pastoral longing and sends Timothy to strengthen them.",
      "word_count": 46
    },
    {
      "type": "context",
      "sequence": 3,
      "audio_script": "Thessalonian believers faced hostility soon after conversion and needed reassurance.",
      "word_count": 10
    },
    {
      "type": "analysis",
      "sequence": 4,
      "audio_script": "Conversion includes turning and waiting: renouncing idols and expecting Christ. Healthy churches are formed by gospel reception, imitation, and multiplication through suffering.",
      "word_count": 22
    },
    {
      "type": "themes",
      "sequence": 5,
      "audio_script": "Key themes include conversion, discipleship, perseverance, pastoral care, and eschatological hope.",
      "word_count": 11
    },
    {
      "type": "question",
      "sequence": 6,
      "audio_script": "Review question: What did Paul commend the Thessalonians for in 1 Thessalonians 1? Answer: their work of faith, labor of love, and steadfastness of hope in the Lord Jesus Christ — and their example that spread throughout Macedonia and Achaia.",
      "correct_answer": "work of faith, labor of love, steadfastness of hope — and their example spread to all Macedonia and Achaia",
      "acceptable_variants": [
        "the three virtues — faith hope love expressed in work labor and steadfastness",
        "their faith became known throughout the region without paul needing to say anything",
        "1 thessalonians 1 — work of faith labor of love hope of the lord, and a widespread testimony"
      ],
      "word_count": 40
    },
    {
      "type": "close",
      "sequence": 7,
      "audio_script": "Hope in Christ's return strengthens endurance. Next, Paul explains holiness and the resurrection hope of believers.",
      "word_count": 16
    }
  ],
  "metadata": {
    "difficulty": "intermediate",
