    "canonical_order": 54
  },
  "vocabulary": [
    {
      "term": "overseer",
      "definition": "The Greek episkopos in 1 Timothy 3:1-7 translated bishop or elder; the qualifications Paul gives are character-based rather than skill-based, centered on being above reproach"
    },
    {
      "term": "godliness with contentment",
      "definition": "Paul's description of great gain in 1 Timothy 6:6; the antidote to the love of money is not poverty but a combination of piety and satisfaction with what God provides"
